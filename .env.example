# ──────────────────────────────────────────────────────────────
# drust configuration. Copy to .env and fill in real values.
# .env is gitignored; .env.example is committed for reference.
# ──────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────
DRUST_LOG_DIR=/var/log/drust
DRUST_DATA_DIR=/var/lib/drust

# Externally-reachable base URL of your drust deployment.
# Required when any OAuth provider is configured.
# Bare host with NO path suffix — drust internally appends "/drust/..."
# to match the Caddy `handle_path /drust/*` mount. So if you register
# the redirect_uri with Google as
#   https://drust.example.com/drust/admin/oauth/google/callback
# then DRUST_PUBLIC_URL=https://drust.example.com (no trailing slash, no path).
DRUST_PUBLIC_URL=

# ── Admin bootstrap (first boot only — afterwards canonical in meta.sqlite) ─
DRUST_INIT_ADMIN_USERNAME=admin
DRUST_INIT_ADMIN_PASSWORD=changeme

# ── Admin OAuth (v1.11+, all optional) ────────────────────────
# Leave a CLIENT_ID/SECRET pair empty to disable that provider.
# See docs/oauth-setup.md for the provider registration walkthrough.
DRUST_OAUTH_GOOGLE_CLIENT_ID=
DRUST_OAUTH_GOOGLE_CLIENT_SECRET=
DRUST_OAUTH_GITHUB_CLIENT_ID=
DRUST_OAUTH_GITHUB_CLIENT_SECRET=

# Comma-separated email allowlist (lowercased on parse).
# Required when any OAuth provider is configured.
DRUST_ADMIN_OAUTH_ALLOWED_EMAILS=

# ── Garage (object storage, optional, v1.4+) ──────────────────
GARAGE_S3_ENDPOINT=
GARAGE_S3_ACCESS_KEY=
GARAGE_S3_SECRET_KEY=

# ── Quota & guards ────────────────────────────────────────────
DRUST_DISK_MIN_FREE_PCT=20
DRUST_INDEX_LARGE_TABLE_ROWS=1000000

# v1.24 — audit log storage flag. Default is true (writes go to both
# JSONL and SQLite). Set to "false" or "0" after v1.25 validation to
# stop the JSONL writer. v1.26 removes this flag.
AUDIT_DUAL_WRITE=true
