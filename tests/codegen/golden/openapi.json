{
  "openapi": "3.1.0",
  "info": {
    "title": "drust tenant demo",
    "version": "1.0"
  },
  "servers": [
    {
      "url": "https://example.com/drust"
    }
  ],
  "components": {
    "schemas": {
      "FilterAst": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "op",
              "field",
              "value"
            ],
            "properties": {
              "op": {
                "type": "string",
                "enum": [
                  "eq",
                  "neq",
                  "lt",
                  "lte",
                  "gt",
                  "gte",
                  "like",
                  "in"
                ]
              },
              "field": {
                "type": "string"
              },
              "value": {}
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "filters"
            ],
            "properties": {
              "op": {
                "type": "string",
                "enum": [
                  "and",
                  "or"
                ]
              },
              "filters": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/FilterAst"
                }
              }
            }
          },
          {
            "type": "object",
            "required": [
              "op",
              "filter"
            ],
            "properties": {
              "op": {
                "type": "string",
                "enum": [
                  "not"
                ]
              },
              "filter": {
                "$ref": "#/components/schemas/FilterAst"
              }
            }
          }
        ]
      },
      "Posts": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": [
              "string",
              "null"
            ],
            "description": "Markdown body"
          },
          "author_id": {
            "type": "integer",
            "description": "Foreign key to `users`."
          },
          "embedding": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "number"
            },
            "minItems": 1536,
            "maxItems": 1536
          },
          "rating": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1.0,
            "maximum": 5.0
          },
          "tier": {
            "type": [
              "integer",
              "null"
            ],
            "enum": [
              1,
              2,
              3
            ]
          },
          "status": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "draft",
              "published"
            ]
          },
          "slug": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 64
          }
        },
        "required": [
          "title",
          "author_id"
        ],
        "description": "Blog posts"
      },
      "PostsInsert": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "body": {
            "type": [
              "string",
              "null"
            ],
            "description": "Markdown body"
          },
          "author_id": {
            "type": "integer",
            "description": "Foreign key to `users`."
          },
          "embedding": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "number"
            },
            "minItems": 1536,
            "maxItems": 1536
          },
          "rating": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1.0,
            "maximum": 5.0
          },
          "tier": {
            "type": [
              "integer",
              "null"
            ],
            "enum": [
              1,
              2,
              3
            ]
          },
          "status": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "draft",
              "published"
            ]
          },
          "slug": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 64
          }
        },
        "required": [
          "title",
          "author_id"
        ]
      },
      "PostsUpdate": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "body": {
            "type": [
              "string",
              "null"
            ],
            "description": "Markdown body"
          },
          "author_id": {
            "type": "integer",
            "description": "Foreign key to `users`."
          },
          "embedding": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "type": "number"
            },
            "minItems": 1536,
            "maxItems": 1536
          },
          "rating": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1.0,
            "maximum": 5.0
          },
          "tier": {
            "type": [
              "integer",
              "null"
            ],
            "enum": [
              1,
              2,
              3
            ]
          },
          "status": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "draft",
              "published"
            ]
          },
          "slug": {
            "type": [
              "string",
              "null"
            ],
            "maxLength": 64
          }
        }
      },
      "Users": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "email": {
            "type": "string"
          }
        },
        "required": [
          "email"
        ]
      },
      "UsersInsert": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        },
        "required": [
          "email"
        ]
      },
      "UsersUpdate": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/t/demo/records/posts": {
      "get": {
        "summary": "List Posts (simple)",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Posts"
                      }
                    },
                    "total": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Insert into Posts",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostsInsert"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Posts"
                }
              }
            }
          }
        }
      }
    },
    "/t/demo/records/posts/{id}": {
      "get": {
        "summary": "Get one Posts",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Posts"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "put": {
        "summary": "Update Posts",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PostsUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Posts"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete by id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "dry_run",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted (or blast radius if dry_run=true)"
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/t/demo/collections/posts/list": {
      "post": {
        "summary": "List Posts with FilterAst",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "filter": {
                    "$ref": "#/components/schemas/FilterAst"
                  },
                  "sort": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "page": {
                    "type": "integer"
                  },
                  "per_page": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Posts"
                      }
                    },
                    "total": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/t/demo/collections/posts/search": {
      "post": {
        "summary": "Vector similarity search over Posts",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "field",
                  "vector",
                  "k"
                ],
                "properties": {
                  "field": {
                    "type": "string",
                    "enum": [
                      "embedding"
                    ]
                  },
                  "vector": {
                    "type": "array",
                    "items": {
                      "type": "number"
                    }
                  },
                  "k": {
                    "type": "integer"
                  },
                  "metric": {
                    "type": "string",
                    "enum": [
                      "cosine",
                      "l2"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "allOf": [
                      {
                        "$ref": "#/components/schemas/Posts"
                      },
                      {
                        "type": "object",
                        "properties": {
                          "_distance": {
                            "type": "number"
                          }
                        }
                      }
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/t/demo/records/posts/subscribe": {
      "get": {
        "summary": "SSE stream of Posts mutations",
        "responses": {
          "200": {
            "description": "text/event-stream of JSON events"
          }
        }
      }
    },
    "/t/demo/records/users": {
      "get": {
        "summary": "List Users (simple)",
